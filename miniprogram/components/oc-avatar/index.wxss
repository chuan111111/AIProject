.avatar-wrap {
  position: relative;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.avatar-wrap--small,
.avatar--small {
  width: 64px;
  height: 64px;
}

.avatar-wrap--medium,
.avatar--medium {
  width: 96px;
  height: 96px;
}

.avatar-wrap--large,
.avatar--large {
  width: 192px;
  height: 192px;
}

.avatar {
  position: relative;
  transform-origin: 50% 100%;
}

.sprite-canvas,
.sprite-fallback,
.appearance-image {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  image-rendering: pixelated;
}

.sprite-canvas {
  z-index: 20;
  opacity: 0;
}

.sprite-canvas.is-ready { opacity: 1; }
.sprite-fallback { z-index: 10; }
.sprite-fallback.is-hidden { display: none; }
.appearance-image { display: block; }

.is-animated { animation: npc-idle 1.5s steps(2, end) infinite; }
.mood--excited.is-animated { animation: npc-hop .8s steps(2, end) infinite; }
.mood--sad.is-animated { animation: npc-sad 1.8s steps(2, end) infinite; }
.mood--thinking.is-animated { animation: npc-think 1.7s steps(2, end) infinite; }

@keyframes npc-idle {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-2px); }
}

@keyframes npc-hop {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-4px); }
}

@keyframes npc-sad {
  0%, 100% { transform: translateY(2px); }
  50% { transform: translateY(0); }
}

@keyframes npc-think {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-2px); }
}
