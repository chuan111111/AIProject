.chat-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #f5f1fd 0%, #fbfaff 38%);
  overflow: hidden;
}

.persona-bar {
  height: 144rpx;
  padding: 12rpx 28rpx 10rpx;
  display: flex;
  align-items: center;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.72);
  border-bottom: 2rpx solid rgba(96, 75, 142, 0.06);
}

.persona-bar oc-avatar { width: 112rpx; height: 116rpx; display: block; overflow: hidden; }
.persona-copy { margin-left: 8rpx; }
.persona-name { font-size: 30rpx; font-weight: 800; }
.persona-status { margin-top: 5rpx; display: flex; align-items: center; color: #8d8496; font-size: 20rpx; }
.persona-status text { width: 11rpx; height: 11rpx; margin-right: 9rpx; background: #62bd8e; border-radius: 50%; }

.memory-pill { margin-left: auto; padding: 14rpx 18rpx; color: #735dbe; background: #eee9ff; border-radius: 999rpx; font-size: 20rpx; }
.memory-pill text { margin-right: 7rpx; }

.message-list { flex: 1; min-height: 0; padding: 0 26rpx; }
.day-divider { margin: 24rpx 0 18rpx; display: flex; align-items: center; justify-content: center; color: #a098a7; font-size: 19rpx; }
.day-divider::before, .day-divider::after { content: ''; width: 74rpx; height: 2rpx; margin: 0 14rpx; background: #e7e1ed; }

.context-card { margin: 0 auto 28rpx; padding: 17rpx 22rpx; color: #7c7384; background: rgba(255,255,255,0.72); border: 2rpx solid rgba(111, 90, 151, 0.06); border-radius: 20rpx; text-align: center; font-size: 20rpx; }
.context-label { color: #8b74d4; font-size: 17rpx; font-weight: 700; letter-spacing: 2rpx; }
.context-text { margin-top: 4rpx; }

.message-row { margin-bottom: 26rpx; display: flex; align-items: flex-end; }
.message-row--user { justify-content: flex-end; }
.mini-avatar { width: 73rpx; height: 76rpx; margin-right: 12rpx; display: flex; align-items: flex-end; justify-content: center; overflow: hidden; border-radius: 24rpx; background: #eee8ff; }
.mini-avatar oc-avatar { width: 82rpx; height: 91rpx; display: block; transform: translateY(24rpx); }
.message-content { max-width: 75%; }
.bubble { padding: 20rpx 24rpx; border-radius: 27rpx; font-size: 27rpx; line-height: 1.62; }
.bubble--assistant { color: #45404c; background: #fff; border-bottom-left-radius: 8rpx; box-shadow: 0 10rpx 28rpx rgba(75, 58, 98, 0.07); }
.bubble--user { color: #fff; background: linear-gradient(135deg, #8d78dc, #725bc3); border-bottom-right-radius: 8rpx; box-shadow: 0 12rpx 26rpx rgba(111, 86, 193, 0.2); }
.message-meta { margin-top: 7rpx; padding: 0 5rpx; display: flex; color: #aaa2af; font-size: 17rpx; }
.message-row--user .message-meta { justify-content: flex-end; }
.ooc-button { margin-left: 16rpx; color: #8a78c8; }
.evidence-button { margin-left: 16rpx; color: #4e8b71; }
.evidence-panel { margin-top: 12rpx; padding: 20rpx; background: #f7fbf9; border: 2rpx solid #dceee6; border-radius: 20rpx; }
.evidence-head { display: flex; align-items: center; }
.check-icon { width: 42rpx; height: 42rpx; margin-right: 12rpx; display: flex; align-items: center; justify-content: center; color: #fff; background: #60ae88; border-radius: 50%; font-size: 20rpx; font-weight: 800; }
.evidence-head > view:last-child { display: flex; flex-direction: column; }
.evidence-head text { color: #477a64; font-size: 21rpx; font-weight: 750; }
.evidence-head .evidence-score { margin-top: 2rpx; color: #8b9a93; font-size: 17rpx; font-weight: 400; }
.reasoning { margin-top: 15rpx; color: #6b746f; font-size: 20rpx; line-height: 1.55; }
.model-source { margin-top: 9rpx; color: #9b929e; font-size: 17rpx; }
.evidence-group { margin-top: 17rpx; }
.evidence-label { margin-bottom: 8rpx; color: #8f8496; font-size: 17rpx; font-weight: 700; letter-spacing: 1rpx; }
.evidence-item { margin-top: 8rpx; padding: 13rpx 14rpx; background: #fff; border-radius: 14rpx; }
.evidence-item text { color: #745fba; font-size: 16rpx; font-weight: 700; }
.evidence-item view { margin-top: 4rpx; color: #645d68; font-size: 19rpx; line-height: 1.45; }
.evidence-item--memory text { color: #4c9475; }
.no-evidence { margin-top: 14rpx; color: #9a929e; font-size: 18rpx; }

.typing-bubble { height: 62rpx; padding: 0 24rpx; display: flex; align-items: center; background: #fff; border-radius: 25rpx 25rpx 25rpx 8rpx; box-shadow: 0 10rpx 25rpx rgba(75, 58, 98, 0.07); }
.typing-bubble text { width: 9rpx; height: 9rpx; margin: 0 5rpx; background: #a998d4; border-radius: 50%; animation: typing 1.1s ease-in-out infinite; }
.typing-bubble text:nth-child(2) { animation-delay: 0.18s; }
.typing-bubble text:nth-child(3) { animation-delay: 0.36s; }
.typing-wrap { display: flex; flex-direction: column; align-items: flex-start; }
.checking-text { margin-top: 6rpx; color: #9b91a2; font-size: 17rpx; }
.memory-proposal { margin: 18rpx 0 28rpx 85rpx; padding: 23rpx; background: linear-gradient(135deg, #fff8f2, #fff); border: 2rpx solid #f0dcd0; border-radius: 24rpx; box-shadow: 0 10rpx 30rpx rgba(104,75,62,0.07); }
.proposal-top { display: flex; align-items: center; }
.proposal-icon { width: 44rpx; height: 44rpx; margin-right: 12rpx; display: flex; align-items: center; justify-content: center; color: #a86c4f; background: #ffeadc; border-radius: 14rpx; }
.proposal-top > view:last-child { display: flex; flex-direction: column; }
.proposal-top text { color: #9b634c; font-size: 20rpx; font-weight: 750; }
.proposal-top .proposal-status { color: #af9c94; font-size: 16rpx; font-weight: 400; }
.proposal-text { margin: 17rpx 0; color: #574c4b; font-size: 24rpx; line-height: 1.55; }
.proposal-actions { display: flex; flex-wrap: wrap; gap: 9rpx; }
.proposal-actions button { min-height: 55rpx; padding: 0 14rpx; color: #766d72; background: #f4efee; font-size: 18rpx; }
.proposal-actions .approve { color: #fff; background: #8067cb; }
.proposal-edit textarea { width: 100%; min-height: 90rpx; margin: 15rpx 0; padding: 14rpx; background: #f8f3f1; border-radius: 14rpx; font-size: 21rpx; }
.proposal-edit button { min-height: 60rpx; color: #fff; background: #8067cb; font-size: 20rpx; }
.chat-bottom-anchor { height: 26rpx; }

.composer-wrap { padding: 14rpx 22rpx calc(15rpx + env(safe-area-inset-bottom)); flex-shrink: 0; background: rgba(255,255,255,0.96); border-top: 2rpx solid rgba(96, 75, 142, 0.06); }
.suggestions { width: 100%; white-space: nowrap; margin-bottom: 13rpx; }
.suggestion-row { display: inline-flex; gap: 12rpx; }
.suggestion { padding: 12rpx 18rpx; color: #776a89; background: #f2eef9; border-radius: 999rpx; font-size: 20rpx; }
.suggestion--test { color: #a05e72; background: #ffedf2; }
.composer { min-height: 82rpx; padding: 11rpx 11rpx 11rpx 22rpx; display: flex; align-items: flex-end; background: #f5f2f8; border: 2rpx solid #ebe5f1; border-radius: 28rpx; }
.chat-input { flex: 1; min-height: 56rpx; max-height: 140rpx; padding: 9rpx 0; color: #3f3947; font-size: 26rpx; line-height: 1.45; }
.send-button { width: 58rpx; height: 58rpx; margin-left: 14rpx; display: flex; align-items: center; justify-content: center; color: #b3aabc; background: #e6e0eb; font-size: 32rpx; font-weight: 800; }
.send-button.is-ready { color: #fff; background: #7c64cc; }
.demo-tip { margin-top: 9rpx; color: #aaa2af; text-align: center; font-size: 17rpx; }
.correction-mask { position: fixed; inset: 0; display: flex; align-items: flex-end; background: rgba(34,28,44,0.46); z-index: 100; }
.correction-sheet { width: 100%; max-height: 88vh; padding: 18rpx 30rpx calc(20rpx + env(safe-area-inset-bottom)); overflow-y: auto; background: #fff; border-radius: 36rpx 36rpx 0 0; }
.sheet-handle { width: 72rpx; height: 8rpx; margin: 0 auto 24rpx; background: #ded8e2; border-radius: 999rpx; }
.sheet-kicker { color: #8169c7; font-size: 17rpx; font-weight: 800; letter-spacing: 3rpx; }
.sheet-title { margin-top: 8rpx; font-size: 34rpx; font-weight: 850; }
.sheet-desc { margin-top: 9rpx; color: #8e8694; font-size: 22rpx; line-height: 1.55; }
.reason-grid { margin: 24rpx 0; display: grid; grid-template-columns: repeat(2, 1fr); gap: 11rpx; }
.reason-option { min-height: 70rpx; padding: 15rpx 17rpx; display: flex; align-items: center; justify-content: space-between; color: #6d6573; background: #f6f3f8; border: 2rpx solid transparent; border-radius: 17rpx; font-size: 21rpx; }
.reason-option.is-selected { color: #654db5; background: #f0eaff; border-color: #baa9eb; font-weight: 700; }
.correction-draft { margin-bottom: 23rpx; }
.draft-label { margin-bottom: 9rpx; color: #746b79; font-size: 20rpx; font-weight: 700; }
.correction-draft textarea { width: 100%; min-height: 105rpx; padding: 17rpx; background: #f7f4f8; border-radius: 17rpx; font-size: 22rpx; line-height: 1.5; }
.correction-sheet .primary-button { min-height: 84rpx; font-size: 25rpx; }
.correction-sheet .ghost-button { width: 100%; }

@keyframes typing {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.45; }
  30% { transform: translateY(-6rpx); opacity: 1; }
}

/* Pixel theme overrides */
.chat-page { background:#ead4bb; background-image:linear-gradient(rgba(95,64,83,.08) 2rpx,transparent 2rpx),linear-gradient(90deg,rgba(95,64,83,.08) 2rpx,transparent 2rpx); background-size:28rpx 28rpx; }
.persona-bar,.composer-wrap { background:#fff0d4; border-color:#674b61; }.persona-bar { border-bottom-width:4rpx; }.mini-avatar,.context-card,.memory-pill,.bubble,.evidence-panel,.memory-proposal,.composer,.suggestion,.correction-sheet,.reason-option,.correction-draft textarea { border-radius:6rpx; }
.memory-pill { color:#fff5df; background:#67476f; border:3rpx solid #3e2c45; }.context-card { background:#f6ddb9; border:3rpx solid #8b626b; box-shadow:5rpx 5rpx 0 #bd8975; }.context-label { color:#764f70; }.bubble--assistant { background:#fff5df; border:3rpx solid #72536b; box-shadow:5rpx 5rpx 0 #c08d77; }.bubble--user { background:#76528f; border:3rpx solid #3f2d49; box-shadow:5rpx 5rpx 0 #513961; }.mini-avatar { background:#c6a2ba; border:3rpx solid #60445f; }.suggestion { background:#efd4b5; border:3rpx solid #8b626b; }.suggestion--test { color:#684054; background:#efc0b0; }.composer { background:#fff7e6; border:3rpx solid #86636f; }.send-button,.check-icon,.proposal-icon { border-radius:4rpx; }.send-button.is-ready,.proposal-actions .approve,.proposal-edit button { background:#76528f; }.memory-proposal { background:#ffe6c6; border:3rpx solid #94696d; }.evidence-panel { background:#e7ecd4; border:3rpx solid #718267; }.correction-sheet { background:#fff0d5; border-radius:8rpx 8rpx 0 0; }.reason-option { background:#efd7bb; border:3rpx solid #9a7178; }.reason-option.is-selected { background:#ddc5e4; border-color:#674970; }
