.diary-page { min-height:100vh; background:#ead2b8; background-image:linear-gradient(rgba(99,67,80,.1) 2rpx,transparent 2rpx),linear-gradient(90deg,rgba(99,67,80,.1) 2rpx,transparent 2rpx); background-size:30rpx 30rpx; }.diary-header { display:flex; align-items:flex-end; justify-content:space-between; }.diary-header > view:first-child { width:73%; }.diary-header .page-title { font-size:42rpx; }.diary-header .page-desc { font-size:22rpx; }.header-avatar { width:150rpx; height:180rpx; display:flex; align-items:flex-end; justify-content:center; overflow:hidden; background:#c7a4b6; }
.source-strip { margin:30rpx 0; padding:20rpx 12rpx; display:flex; align-items:center; background:#fff0d7; }.source-item { flex:1; display:flex; flex-direction:column; align-items:center; color:#836c76; font-size:16rpx; font-weight:800; }.source-number { margin-bottom:3rpx; color:#4f394e; font-size:29rpx; font-weight:900; }.source-divider { width:3rpx; height:45rpx; background:#8e6570; }
.comic-wrap { padding:24rpx; background:#fff2d9; }.comic-head { display:flex; align-items:flex-start; justify-content:space-between; }.comic-title { margin-top:13rpx; font-size:27rpx; font-weight:900; }.mood-chip { padding:10rpx 13rpx; color:#fff8e7; background:#80546e; border:3rpx solid #49354a; font-size:17rpx; font-weight:900; }.comic-grid { margin-top:22rpx; display:grid; grid-template-columns:repeat(2,1fr); gap:12rpx; }.comic-frame { overflow:hidden; background:#ffe8c5; border:4rpx solid #4d354b; }.frame-scene { height:240rpx; position:relative; overflow:hidden; background:#b98aa3; border-bottom:4rpx solid #4d354b; }.frame-scene::after { content:''; position:absolute; left:0; right:0; bottom:0; height:68rpx; background:repeating-linear-gradient(90deg,#aa6b55 0,#aa6b55 44rpx,#824c43 44rpx,#824c43 48rpx); }.frame-window { width:72rpx; height:70rpx; position:absolute; left:20rpx; top:20rpx; background:#efa27f; border:5rpx solid #4b3548; box-shadow:0 31rpx 0 -28rpx #4b3548 inset,34rpx 0 0 -31rpx #4b3548 inset; }.frame-table { width:84rpx; height:50rpx; position:absolute; right:12rpx; bottom:48rpx; background:#795044; border:4rpx solid #4b333b; }.frame-lamp { display:none; }.frame-avatar { position:absolute; left:50%; bottom:21rpx; transform:translateX(-50%) scale(.68); transform-origin:50% 100%; z-index:4; }.frame-index { position:absolute; right:7rpx; top:7rpx; padding:4rpx 7rpx; color:#fff7e2; background:#49354a; font-size:14rpx; font-weight:900; z-index:6; }.scene--snack { background:#c9a069; }.scene--snack .frame-table::before { content:'◆'; position:absolute; left:27rpx; top:-28rpx; color:#f5cf70; font-size:28rpx; }.scene--talk { background:#96aa84; }.scene--talk .frame-window { background:#d2d792; }.scene--night { background:#5b567c; }.scene--night .frame-window { background:#594f82; box-shadow:inset 24rpx 14rpx 0 -16rpx #f6dc82; }.frame-caption { min-height:88rpx; padding:12rpx; color:#513c4d; font-size:18rpx; line-height:1.45; font-weight:800; }
.diary-narration { margin-top:19rpx; padding:19rpx; color:#55404f; background:#f1d4b4; border:3rpx dashed #865e68; }.diary-narration > text { color:#8b5971; font-size:15rpx; font-weight:900; letter-spacing:2rpx; }.diary-narration > view { margin-top:8rpx; font-size:21rpx; line-height:1.65; }.diary-narration .paper-sign { text-align:right; font-weight:900; }.diary-actions { margin-top:20rpx; display:grid; grid-template-columns:.8fr 1.2fr; gap:14rpx; }.diary-actions button { min-height:76rpx; font-size:20rpx; }
.empty-card { padding:42rpx 28rpx 24rpx; text-align:center; }.empty-pixels { height:145rpx; display:flex; align-items:center; justify-content:center; gap:18rpx; color:#76528f; font-size:55rpx; }.empty-pixels text:nth-child(2) { color:#d08178; transform:translateY(-25rpx); }.empty-title { font-size:29rpx; font-weight:900; }.empty-desc { margin:14rpx auto 27rpx; color:#806a75; font-size:21rpx; line-height:1.6; }.empty-card .primary-button { font-size:22rpx; }.history-section { margin-top:38rpx; }.history-heading { margin-bottom:15rpx; display:flex; align-items:center; justify-content:space-between; }.history-count { color:#806979; font-size:16rpx; font-weight:900; }.history-card { margin-bottom:15rpx; padding:20rpx; }.history-date { color:#6a4961; font-size:20rpx; font-weight:900; }.history-content { margin-top:9rpx; color:#705b68; font-size:19rpx; line-height:1.55; }.privacy-footer { margin-top:32rpx; color:#896f78; text-align:center; font-size:16rpx; font-weight:800; letter-spacing:1rpx; }
