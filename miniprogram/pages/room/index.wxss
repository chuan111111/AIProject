.room-page { min-height:100vh; padding:24rpx 22rpx calc(42rpx + env(safe-area-inset-bottom)); background:#e9d3b8; background-image:linear-gradient(rgba(95,64,83,.1) 2rpx,transparent 2rpx),linear-gradient(90deg,rgba(95,64,83,.1) 2rpx,transparent 2rpx); background-size:28rpx 28rpx; }
.room-header { height:94rpx; display:flex; align-items:center; justify-content:space-between; }
.room-title-wrap { display:flex; align-items:center; }.status-dot { width:15rpx; height:15rpx; margin-right:13rpx; background:#72a65e; border:3rpx solid #40523d; box-shadow:5rpx 0 0 rgba(64,82,61,.22); }.room-name { font-size:28rpx; font-weight:900; }.room-status { margin-top:3rpx; color:#866c75; font-size:17rpx; font-weight:800; letter-spacing:1rpx; }.pixel-lock { padding:10rpx 12rpx; color:#fff5df; background:#5f405f; border:4rpx solid #34263b; font-size:16rpx; font-weight:900; }
.room-scene { height:820rpx; position:relative; overflow:hidden; background:#9d6d75; box-shadow:8rpx 8rpx 0 #8d5d57; }
.room-backdrop { position:absolute; inset:0; width:100%; height:100%; image-rendering:pixelated; }
.scene-grid { position:absolute; inset:0; opacity:.1; background-image:linear-gradient(#402e3c 2rpx,transparent 2rpx),linear-gradient(90deg,#402e3c 2rpx,transparent 2rpx); background-size:24rpx 24rpx; pointer-events:none; }
.speech-bubble { position:absolute; max-width:440rpx; right:24rpx; top:24rpx; padding:17rpx 20rpx; color:#443447; background:#fff3d9; border:4rpx solid #4b354b; box-shadow:6rpx 6rpx 0 rgba(75,53,75,.35); font-size:22rpx; line-height:1.5; z-index:8; }.scene-source { margin-top:7rpx; padding-top:7rpx; color:#8e6f78; border-top:3rpx dashed #c89e88; font-size:15rpx; }.bubble-tail { position:absolute; width:18rpx; height:18rpx; right:40rpx; bottom:-20rpx; background:#fff3d9; border-right:4rpx solid #4b354b; border-bottom:4rpx solid #4b354b; }
.residents { position:absolute; left:0; right:0; bottom:52rpx; height:430rpx; display:flex; align-items:flex-end; justify-content:center; z-index:5; }
.resident { display:flex; flex-direction:column; align-items:center; transition:.2s; }.resident-count--2 .resident,.resident-count--3 .resident { margin:0 -8rpx; }.resident-count--1 .resident { margin:0; }.resident-name { margin-top:-9rpx; padding:6rpx 10rpx; color:#fff7e3; background:#4d364e; border:3rpx solid #2f2334; font-size:15rpx; font-weight:900; white-space:nowrap; }.empty-slot { width:118rpx; height:145rpx; margin:0 8rpx 37rpx; display:flex; flex-direction:column; align-items:center; justify-content:center; color:#694e60; background:rgba(255,239,208,.72); border:4rpx dashed #694e60; font-size:16rpx; font-weight:800; }.empty-slot text { font-size:43rpx; line-height:1; }.empty-slot view { margin-top:8rpx; }.scene-tip { position:absolute; left:50%; bottom:10rpx; transform:translateX(-50%); width:86%; padding:7rpx; color:#fff6e1; background:rgba(55,38,55,.84); text-align:center; font-size:15rpx; z-index:8; }
.quick-actions { width:88%; margin:-18rpx auto 0; padding:16rpx 12rpx; position:relative; z-index:9; display:flex; justify-content:space-around; background:#fff1d5; }.quick-action { min-width:100rpx; display:flex; flex-direction:column; align-items:center; color:#61495b; font-size:17rpx; font-weight:900; }.quick-icon { width:50rpx; height:50rpx; margin-bottom:6rpx; display:flex; align-items:center; justify-content:center; color:#fff4dc; background:#76528f; border:3rpx solid #46334f; box-shadow:4rpx 4rpx 0 #c48671; font-size:24rpx; }
.story-panel { margin-top:32rpx; padding:27rpx 23rpx; }.panel-heading { display:flex; justify-content:space-between; align-items:flex-start; }.panel-heading .section-title { margin-top:12rpx; }.panel-subtitle { margin-top:6rpx; color:#8b7078; font-size:18rpx; }.more-home { padding:8rpx 10rpx; color:#fff5df; background:#6b4a6f; border:3rpx solid #3f2d45; font-size:15rpx; font-weight:900; }
.feature-grid { margin-top:23rpx; display:grid; gap:14rpx; }.feature-card { min-height:104rpx; padding:17rpx; display:flex; align-items:center; background:#e7d4ec; border:4rpx solid #62466d; box-shadow:5rpx 5rpx 0 #b8878a; }.feature-card--warm { background:#f0d0ad; border-color:#8c5e56; }.feature-card--green { background:#d5dfbd; border-color:#587050; }.feature-number { width:48rpx; height:48rpx; margin-right:15rpx; display:flex; align-items:center; justify-content:center; color:#fff; background:#5c405e; border:3rpx solid #38293d; font-size:17rpx; font-weight:900; }.feature-copy { flex:1; }.feature-title { font-size:23rpx; font-weight:900; }.feature-desc { margin-top:4rpx; color:#765f6c; font-size:17rpx; line-height:1.4; }.feature-arrow { font-size:20rpx; font-weight:900; }
.memory-strip { margin-top:20rpx; padding:17rpx; background:#fff0d6; border:3rpx dashed #8d626c; }.memory-strip text { color:#8b5870; font-size:15rpx; font-weight:900; letter-spacing:2rpx; }.memory-strip view { margin-top:7rpx; color:#5d4858; font-size:20rpx; line-height:1.5; }.room-footer-actions { margin-top:19rpx; display:grid; grid-template-columns:repeat(2,1fr); gap:13rpx; }.room-footer-actions button { min-height:70rpx; font-size:20rpx; }
